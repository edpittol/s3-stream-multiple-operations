#!/bin/bash
set -e

# Benchmark orchestrator: sweeps RTT 0/10/20/40 ms, runs benchmark in fresh process per data point
# Outputs CSV to results/benchmark-<timestamp>.csv with columns:
# scenario, op, backend, rtt_ms, n, median_ns, p95_ns, min_ns, max_ns

# Runs against the instance selected by the Compose project name (auto-derived
# from the working directory, or `-p <name>`).
PROJECT=""
while getopts "p:" opt; do
  case "$opt" in
    p) PROJECT="$OPTARG" ;;
    *) echo "Usage: bin/env bench [-p <project-name>]" >&2; exit 1 ;;
  esac
done

dc() { docker compose ${PROJECT:+-p "$PROJECT"} "$@"; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
RESULTS_DIR="$PROJECT_ROOT/results"

# Create results directory
mkdir -p "$RESULTS_DIR"

# Output file with timestamp. Written under /app/results in the php container,
# which is bind-mounted to $RESULTS_DIR on the host.
TIMESTAMP=$(date +%s)
CONTAINER_OUTPUT="results/benchmark-$TIMESTAMP.csv"
OUTPUT_FILE="$RESULTS_DIR/benchmark-$TIMESTAMP.csv"

# RTT values to sweep
RTT_VALUES=(0 10 20 40)

# Operations to benchmark
OPS=("file_exists" "stat" "file_put_contents")

# Backends
BACKENDS=("local" "s3")

echo "Starting benchmark sweep..."
echo "Output: $OUTPUT_FILE"
echo ""

# Write CSV header
echo "scenario,op,backend,rtt_ms,n,median_ns,p95_ns,min_ns,max_ns" > "$OUTPUT_FILE"

# Sweep across all combinations
for rtt in "${RTT_VALUES[@]}"; do
    echo "Setting Toxiproxy latency to ${rtt}ms..."

    # Configure Toxiproxy via the container CLI over the internal network
    # (no host admin port). Clear any prior latency toxic first so sweep steps
    # don't stack, then add the current one for rtt > 0.
    for prev in "${RTT_VALUES[@]}"; do
        dc exec -T toxiproxy /toxiproxy-cli toxic delete -n "latency-${prev}ms" minio > /dev/null 2>&1 || true
    done
    if [ "$rtt" -gt 0 ]; then
        dc exec -T toxiproxy /toxiproxy-cli toxic add \
            -t latency -n "latency-${rtt}ms" --upstream \
            -a "latency=$rtt" -a "jitter=0" minio > /dev/null 2>&1 \
            || echo "  (Warning: Could not configure Toxiproxy latency - is the stack up?)"
    fi

    # Small delay to ensure Toxiproxy is ready
    sleep 0.5

    # Run benchmark for each operation and backend
    for op in "${OPS[@]}"; do
        for backend in "${BACKENDS[@]}"; do
            echo "  Benchmarking: op=$op backend=$backend rtt=${rtt}ms"

            # Run benchmark in a fresh process inside the php container, which
            # reaches Toxiproxy over the internal network (S3_ENDPOINT).
            dc exec -T php php src/benchmark.php \
                --backend "$backend" \
                --op "$op" \
                --rtt-ms "$rtt" \
                --output "$CONTAINER_OUTPUT"
        done
    done
done

echo ""
echo "✓ RTT-sweep benchmark complete!"
echo "Results written to: $OUTPUT_FILE"

# Calculate and display reconstructed page-time figure
echo ""
echo "Reconstructed page-time analysis (median per-op × 88):"
awk -F',' 'NR>1 {
    op=$2;
    median=$6;
    ops_per_page=88;
    page_time_ns=median*ops_per_page;
    page_time_ms=page_time_ns/1000000;
    print "  " $3 " / " op ": " median "ns × 88 = " int(page_time_ms) "ms"
}' "$OUTPUT_FILE" | sort | uniq

echo ""
echo "Verifying latency scaling with RTT:"
awk -F',' 'NR>1 && $4 != prevRtt {
    if (prevRtt != "") print ""
    prevRtt=$4;
    print "  RTT " $4 "ms:"
}
NR>1 {
    op=$2;
    median=$6;
    printf "    %-20s: %d ns\n", op, median
}' "$OUTPUT_FILE"

# Run cache-scope benchmark
echo ""
echo "---"
echo "Running cache-scope benchmark..."
echo ""
dc exec -T php php bin/benchmark-cache-scope.php

echo ""
echo "✓ All benchmarks complete!"

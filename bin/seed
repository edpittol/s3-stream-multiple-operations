#!/bin/bash
# Seed the benchmark bucket with 200 distinct ~1 KB objects via PHP SDK through Toxiproxy.
# Run this in the php container with the Docker environment up.

set -e

# Seeds the instance selected by the Compose project name (auto-derived from
# the working directory, or `-p <name>`).
PROJECT=""
while getopts "p:h" opt; do
  case "$opt" in
    p) PROJECT="$OPTARG" ;;
    h) echo "Usage: bin/seed [-p <project-name>]"; exit 0 ;;
    *) echo "Usage: bin/seed [-p <project-name>]" >&2; exit 1 ;;
  esac
done

dc() { docker compose ${PROJECT:+-p "$PROJECT"} "$@"; }

echo "Running seed script in php container..."
dc exec -T php php src/seed.php

exit $?
